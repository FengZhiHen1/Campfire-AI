{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agents.skills/module-spec-writer/contract.schema.json",
  "title": "Module Interface Contract Schema",
  "description": "定义模块对外接口的 JSON Schema 格式标准。所有 docs/contracts/ 下的契约文件必须符合此 Schema。",
  "type": "object",
  "required": ["$schema", "$id", "title", "type"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "http://json-schema.org/draft-07/schema#",
      "description": "JSON Schema 版本标识，固定值"
    },
    "$id": {
      "type": "string",
      "description": "契约文件的唯一标识 URI，格式: docs/contracts/{module-id}/{ContractName}.json",
      "pattern": "^docs/contracts/[A-Z]\\d{2,3}/[A-Z][a-zA-Z0-9]+\\.json$"
    },
    "title": {
      "type": "string",
      "description": "契约类型的名称（即代码中的类名/类型名），必须与代码中的命名完全一致",
      "pattern": "^[A-Z][a-zA-Z0-9]+$"
    },
    "description": {
      "type": "string",
      "description": "业务语义说明，解释该类型在业务流程中的角色"
    },
    "type": {
      "type": "string",
      "enum": ["object", "string", "integer", "number", "boolean", "array"],
      "description": "JSON Schema 基础类型"
    },

    "x-defined-by": {
      "type": "string",
      "description": "定义该契约的模块编号",
      "pattern": "^[A-Z]\\d{2,3}$"
    },
    "x-consumers": {
      "type": "array",
      "description": "消费（引用）该契约的模块编号列表",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]\\d{2,3}$"
      },
      "uniqueItems": true
    },
    "x-maturity": {
      "type": "string",
      "enum": ["draft", "stable", "deprecated"],
      "description": "契约成熟度。draft=仅一个模块使用，可自由变更；stable=多个模块引用，变更需走流程；deprecated=已废弃，待迁移"
    },
    "x-contract-type": {
      "type": "string",
      "enum": ["input", "output", "shared-model", "shared-enum", "error-code", "event"],
      "description": "契约在模块接口中的角色"
    },
    "x-version": {
      "type": "string",
      "description": "契约版本号，语义化版本格式",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },

    "properties": {
      "type": "object",
      "description": "当 type=object 时，定义各字段的 Schema"
    },
    "required": {
      "type": "array",
      "description": "必填字段名列表",
      "items": { "type": "string" }
    },
    "enum": {
      "type": "array",
      "description": "当 type=string/integer/number 时，枚举允许值"
    },
    "items": {
      "type": "object",
      "description": "当 type=array 时，定义元素 Schema"
    },
    "anyOf": {
      "type": "array",
      "description": "联合类型（如 str | None），按 JSON Schema 标准"
    },
    "oneOf": {
      "type": "array",
      "description": "互斥联合类型，按 JSON Schema 标准"
    },
    "$ref": {
      "type": "string",
      "description": "引用其他契约文件，格式为相对路径",
      "pattern": "^\\./[A-Z][a-zA-Z0-9]+\\.json$"
    },
    "additionalProperties": {
      "type": ["boolean", "object"],
      "description": "是否允许未声明的额外字段。对外接口契约建议设为 false"
    }
  },

  "additionalProperties": false,

  "definitions": {
    "fieldSchema": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {},
        "description": {
          "type": "string",
          "description": "字段业务语义"
        },
        "examples": {
          "type": "array",
          "description": "示例值列表"
        },
        "default": {
          "description": "默认值"
        },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "minLength": { "type": "integer" },
        "maxLength": { "type": "integer" },
        "pattern": { "type": "string" },
        "format": {
          "type": "string",
          "enum": ["email", "uuid", "date-time", "uri", "ipv4", "ipv6"]
        },
        "enum": { "type": "array" }
      }
    }
  }
}
