{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/CASE-04/ChunkMetadata.json",
  "title": "ChunkMetadata",
  "description": "case_chunks.metadata JSONB 字段的结构化定义。包含 4 个检索过滤维度键（behavior_type, age_range, severity, evidence_level），CSLT-02 RAG 检索时使用这些键名作为过滤条件。键名变更需同步通知 CSLT-02 模块维护者。",
  "type": "object",
  "x-defined-by": "CASE-04",
  "x-consumers": ["CSLT-02"],
  "x-maturity": "draft",
  "x-contract-type": "output",
  "x-version": "1.0.0",
  "properties": {
    "behavior_type": {
      "type": "string",
      "description": "行为类型，对应 cases.behavior_type 枚举值，取值：自伤/攻击/刻板/逃跑/情绪崩溃/其他"
    },
    "age_range": {
      "type": "string",
      "description": "年龄区间，格式为 'min-max' 字符串",
      "examples": ["3-6", "7-12", "13-18"]
    },
    "severity": {
      "type": "string",
      "description": "严重程度枚举值",
      "enum": ["轻度", "中度", "重度"]
    },
    "evidence_level": {
      "type": "string",
      "description": "循证等级枚举值",
      "enum": ["循证实践(EBP)", "机构经验总结(INSTITUTIONAL)", "个案观察记录(OBSERVATIONAL)"]
    }
  },
  "required": ["behavior_type", "age_range", "severity", "evidence_level"],
  "additionalProperties": false
}
