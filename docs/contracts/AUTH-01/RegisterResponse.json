{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/AUTH-01/RegisterResponse.json",
  "title": "RegisterResponse",
  "description": "用户注册成功响应体。包含固定结果标识和全局唯一的用户 UUID。注册成功时返回 201 Created，不包含 JWT Token。",
  "type": "object",
  "x-defined-by": "AUTH-01",
  "x-consumers": ["AUTH-05"],
  "x-maturity": "draft",
  "x-contract-type": "output",
  "x-version": "1.0.0",
  "properties": {
    "result": {
      "type": "string",
      "const": "success",
      "description": "注册结果，成功时固定为 'success'。非成功场景通过 HTTP 状态码（422/409/500）+ 错误响应体表达。",
      "examples": ["success"]
    },
    "user_id": {
      "type": "string",
      "format": "uuid",
      "description": "系统为用户生成的全局唯一标识（UUIDv4）。由 PostgreSQL gen_random_uuid() 在数据库层面生成，36 字符标准形式（含连字符）。注册后不可变更。",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "examples": ["a1b2c3d4-e5f6-7890-abcd-ef1234567890"]
    },
    "message": {
      "type": "string",
      "default": "注册成功",
      "description": "面向用户的可读提示信息。",
      "examples": ["注册成功"]
    }
  },
  "required": ["result", "user_id"],
  "additionalProperties": false
}
