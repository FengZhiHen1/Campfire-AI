{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/OBS-01/LogInput.json",
  "title": "LogInput",
  "description": "日志写入接口的输入参数，由调用方传入",
  "type": "object",
  "required": ["level", "message", "service"],
  "properties": {
    "level": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARNING", "ERROR"],
      "description": "日志严重等级",
      "examples": ["INFO"]
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "description": "日志消息正文，中文或英文，长度 1-4096 字符",
      "examples": ["用户登录成功"]
    },
    "service": {
      "type": "string",
      "minLength": 1,
      "description": "来源服务名称，必须为平台已注册的服务名称",
      "examples": ["api-server"]
    },
    "op_type": {
      "type": ["string", "null"],
      "description": "操作类型。关键动作（AI调用、权限拒绝、工单创建）必须填写",
      "examples": ["AI调用"]
    },
    "extra": {
      "type": ["object", "null"],
      "description": "结构化补充数据，键长度不超过64字符，值长度不超过1024字符",
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "x-defined-by": "OBS-01",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "input",
  "x-version": "1.0.0"
}
