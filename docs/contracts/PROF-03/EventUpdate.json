{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/PROF-03/EventUpdate.json",
  "title": "EventUpdate",
  "description": "更新事件记录的输入模型（Merge Patch 语义）。所有字段默认为 null（表示不修改此字段）。仅用户显式提供的非 null 字段写入数据库。setting 字段传入显式 null 表示清除已设置的发生场景。更新时 event_time 同样需通过 30 天追溯期校验。",
  "type": "object",
  "x-defined-by": "PROF-03",
  "x-consumers": ["PROF-07"],
  "x-maturity": "draft",
  "x-contract-type": "input",
  "x-version": "1.0.0",
  "properties": {
    "event_time": {
      "oneOf": [
        {"type": "string", "format": "date-time"},
        {"type": "null"}
      ],
      "default": null,
      "description": "修改后的事件实际发生时间，null 表示不修改此字段"
    },
    "behavior_type": {
      "oneOf": [
        {"type": "string", "enum": ["刻板行为", "情绪崩溃", "自伤行为", "攻击行为", "社交退缩", "多动"]},
        {"type": "null"}
      ],
      "default": null,
      "description": "修改后的行为类型，null 表示不修改此字段"
    },
    "severity_level": {
      "oneOf": [
        {"type": "string", "enum": ["轻", "中", "重"]},
        {"type": "null"}
      ],
      "default": null,
      "description": "修改后的严重程度，null 表示不修改此字段"
    },
    "setting": {
      "description": "修改后的发生场景。传入 null（显式）表示清除已设置的发生场景（将数据库值设为 NULL）"
    },
    "trigger_description": {
      "oneOf": [
        {"type": "string", "minLength": 1, "maxLength": 2000},
        {"type": "null"}
      ],
      "default": null,
      "description": "修改后的触发因素描述，null 表示不修改此字段"
    },
    "manifestation": {
      "oneOf": [
        {"type": "string", "minLength": 1, "maxLength": 2000},
        {"type": "null"}
      ],
      "default": null,
      "description": "修改后的具体表现描述，null 表示不修改此字段"
    },
    "intervention_tried": {
      "oneOf": [
        {"type": "string", "minLength": 1, "maxLength": 2000},
        {"type": "null"}
      ],
      "default": null,
      "description": "修改后的尝试干预措施，null 表示不修改此字段"
    },
    "intervention_result": {
      "oneOf": [
        {"type": "string", "minLength": 1, "maxLength": 2000},
        {"type": "null"}
      ],
      "default": null,
      "description": "修改后的干预结果，null 表示不修改此字段"
    },
    "tags": {
      "oneOf": [
        {
          "type": "array",
          "items": {"type": "string", "maxLength": 10},
          "maxItems": 5
        },
        {"type": "null"}
      ],
      "default": null,
      "description": "修改后的自定义标签列表，null 表示不修改此字段"
    }
  },
  "additionalProperties": false
}
