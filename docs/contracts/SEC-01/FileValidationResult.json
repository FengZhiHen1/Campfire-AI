{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-01/FileValidationResult.json",
  "title": "FileValidationResult",
  "description": "文件安全校验结果",
  "type": "object",
  "x-defined-by": "SEC-01",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "output",
  "x-version": "1.0.0",
  "properties": {
    "is_valid": {
      "type": "boolean",
      "description": "文件是否通过三层递进校验",
      "examples": [true, false]
    },
    "reason": {
      "description": "校验失败时的原因说明；通过时为 null",
      "oneOf": [
        {"type": "string", "examples": ["文件扩展名 .exe 不在允许白名单中"]},
        {"type": "null"}
      ],
      "default": null
    }
  },
  "required": ["is_valid"],
  "additionalProperties": false
}
