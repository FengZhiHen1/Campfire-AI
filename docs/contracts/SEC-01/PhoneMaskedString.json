{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-01/PhoneMaskedString.json",
  "title": "PhoneMaskedString",
  "description": "脱敏后的手机号字符串包装类型，格式：前3位+****+后4位",
  "type": "object",
  "x-defined-by": "SEC-01",
  "x-consumers": ["SEC-03"],
  "x-maturity": "draft",
  "x-contract-type": "output",
  "x-version": "1.0.0",
  "properties": {
    "value": {
      "type": "string",
      "description": "脱敏后的手机号字符串，格式 \d{3}****\d{4}；管理员角色返回完整号码",
      "pattern": "^(\\d{3}\\*{4}\\d{4})|(\\d{11})$",
      "examples": ["138****1234", "13800001234"]
    }
  },
  "required": ["value"],
  "additionalProperties": false
}
