{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-01/verify_password.json",
  "title": "verify_password",
  "description": "验证明文密码与 bcrypt 哈希值是否匹配",
  "type": "object",
  "x-defined-by": "SEC-01",
  "x-consumers": ["AUTH-02"],
  "x-maturity": "draft",
  "x-contract-type": "input",
  "x-version": "1.0.0",
  "properties": {
    "plain_password": {
      "type": "string",
      "description": "待验证的明文密码",
      "minLength": 8,
      "maxLength": 64,
      "examples": ["MySecurePass123"]
    },
    "hashed_password": {
      "type": "string",
      "description": "bcrypt 哈希值，格式 $2b$12$...",
      "examples": ["$2b$12$LJ3m4ys3G..."]
    }
  },
  "required": ["plain_password", "hashed_password"],
  "additionalProperties": false
}
