{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-01/RateLimitExceededResponse.json",
  "title": "RateLimitExceededResponse",
  "description": "触发限流时返回的 HTTP 429 响应体",
  "type": "object",
  "x-defined-by": "SEC-01",
  "x-consumers": ["SEC-04"],
  "x-maturity": "draft",
  "x-contract-type": "output",
  "x-version": "1.0.0",
  "properties": {
    "detail": {
      "type": "string",
      "description": "限流提示信息，不暴露限流阈值内部细节",
      "examples": ["请求过于频繁，请在 60 秒后重试"]
    },
    "retry_after_seconds": {
      "type": "integer",
      "description": "建议重试等待秒数",
      "minimum": 1,
      "maximum": 60,
      "examples": [60]
    }
  },
  "required": ["detail", "retry_after_seconds"],
  "additionalProperties": false
}
