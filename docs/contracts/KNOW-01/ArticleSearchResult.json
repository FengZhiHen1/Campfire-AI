{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/KNOW-01/ArticleSearchResult.json",
  "title": "ArticleSearchResult",
  "description": "全文检索结果条目，包含相关度分数和关键词高亮的正文摘要",
  "type": "object",
  "x-defined-by": "KNOW-01",
  "x-consumers": ["KNOW-03", "KNOW-06", "KNOW-07"],
  "x-maturity": "draft",
  "x-contract-type": "output",
  "x-version": "1.0.0",
  "properties": {
    "id": {
      "type": "string",
      "description": "文章唯一标识，UUID v4 格式",
      "format": "uuid"
    },
    "title": {
      "type": "string",
      "description": "文章标题",
      "maxLength": 200
    },
    "category": {
      "$ref": "./ArticleCategory.json"
    },
    "content_snippet": {
      "type": "string",
      "description": "搜索结果正文摘要，包含 <mark> 标签标记的关键词高亮位置",
      "examples": ["<mark>刻板行为</mark>是孤独症谱系障碍的核心症状之一..."]
    },
    "status": {
      "$ref": "./ArticleStatus.json"
    },
    "published_at": {
      "type": "string",
      "description": "首次发布时间，未发布时为 null",
      "format": "date-time"
    },
    "score": {
      "type": "number",
      "description": "相关度分数，由 PostgreSQL ts_rank() 计算，值越高越相关",
      "minimum": 0,
      "examples": [0.85]
    }
  },
  "required": ["id", "title", "category", "content_snippet", "status", "score"],
  "additionalProperties": false
}
