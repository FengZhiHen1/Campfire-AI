{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/KNOW-01/ArticleCreate.json",
  "title": "ArticleCreate",
  "description": "创建科普文章的请求体，由运营管理员在管理后台提交",
  "type": "object",
  "x-defined-by": "KNOW-01",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "input",
  "x-version": "1.0.0",
  "properties": {
    "title": {
      "type": "string",
      "description": "文章标题，概括文章核心主题",
      "minLength": 1,
      "maxLength": 200,
      "examples": ["什么是孤独症的刻板行为"]
    },
    "category": {
      "$ref": "./ArticleCategory.json"
    },
    "content": {
      "type": "string",
      "description": "文章正文内容，必须属于孤独症基础科普范畴",
      "minLength": 1,
      "examples": ["刻板行为是孤独症谱系障碍的核心症状之一..."]
    },
    "related_case_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^CASE-\\d{3}$" },
      "description": "关联的真实案例编号列表，每个编号对应真实案例库中的已存在案例",
      "maxItems": 5,
      "default": [],
      "examples": [["CASE-001", "CASE-015"]]
    }
  },
  "required": ["title", "category", "content"],
  "additionalProperties": false
}
