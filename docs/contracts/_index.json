    "CSLT-05/ConfidenceValidationInput.json": {
      "module": "CSLT-05",
      "type": "object",
      "description": "CSLT-05 置信度后校验的输入参数。由 CSLT-08 编排层在应急方案生成完成后组装，聚合 CSLT-03 的生成结果、CSLT-01 的危机判定结果和编排上下文。"
    },
    "CSLT-05/ConfidenceValidationOutput.json": {
      "module": "CSLT-05",
      "type": "object",
      "description": "CSLT-05 置信度后校验的输出结果。包含置信度分数、判定结论、处理后的方案全文、工单触发状态和降级信息。由 CSLT-08 编排层消费用于前端 UI 展示决策，由 CSLT-06 消费用于持久化到咨询历史。"
    },
    "CSLT-05/ValidationVerdict.json": {
      "module": "CSLT-05",
      "type": "string",
      "description": "CSLT-05 置信度后校验的判定结论枚举。用于下游 CSLT-08 编排层决定前端 UI 展示策略，以及 CSLT-06 持久化到咨询历史记录中。"
    },
    "CSLT-06/ConsultationHistoryCreate.json": {
      "module": "CSLT-06",
      "type": "object",
      "description": "咨询历史归档写入的输入模型。由 CSLT-08 编排层在每次咨询流程完成后组装并传入 CSLT-06。包含本次咨询的完整上下文数据：用户输入、检索案例、生成方案、置信度分数、来源引用等。"
    },
    "CSLT-06/ConsultationHistoryDetail.json": {
      "module": "CSLT-06",
      "type": "object",
      "description": "单次咨询的完整详情。GET /api/v1/consultations/{id} 接口的响应体。包含归档时的全部字段，不做任何二次加工或截断。家属仅能查看本人账号下的记录；request_id 由系统生成为空时返回 null。"
    },
    "CSLT-06/ConsultationHistoryListItem.json": {
      "module": "CSLT-06",
      "type": "object",
      "description": "咨询历史列表摘要条目。GET /api/v1/consultations 列表查询接口返回的 PaginatedResponse.items 中的单条记录。仅包含列表展示所需的最小字段集合：咨询时间、行为描述全文（前端截取前 50 字）、危机等级标签和反馈状态。"
    },
    "PROF-03/EventCreate.json": {
      "module": "PROF-03",
      "type": "object",
      "description": "创建事件记录的输入模型。家属填写事件结构化表单后提交，Service 层校验 30 天追溯期、档案存在性、权限、容量上限后写入 event_logs 表。behavior_type 引用 PROF-01 的 ProfileBehaviorType 枚举，severity_level 引用本模块 SeverityLevel 枚举，setting 引用本模块 EventSetting 枚举。"
    },
    "PROF-03/EventLimitExceededError.json": {
      "module": "PROF-03",
      "type": "object",
      "description": "事件记录容量超限错误响应体（HTTP 409）。当目标档案下的事件记录数达到 500 条上限时，创建新事件的请求被拒绝，返回此错误。结构模式与 PROF-01 ProfileLimitExceededError 一致（detail + error_code + current_count + max_allowed），业务语义不同（事件容量 vs 档案容量），保持独立契约。"
    },
    "PROF-03/EventListItem.json": {
      "module": "PROF-03",
      "type": "object",
      "description": "事件记录列表精简条目输出模型。用于 GET /api/v1/profiles/{profile_id}/events 列表接口，仅包含列表中展示所需的核心字段，不包含完整描述文本。has_professional_note 字段语义与 EventResponse.is_professional 对应但字段命名不同，用于列表视图的可读性表达。"
    },
    "PROF-03/EventResponse.json": {
      "module": "PROF-03",
      "type": "object",
      "description": "事件记录完整详情输出模型。包含 16 个字段，覆盖意图文档 §1.6.2 全部输出字段。recorded_by 和 recorded_by_role 由系统从 JWT 获取（不可由客户端传入）。is_professional 默认为 false，仅 PROF-04 补充评估后设置为 true。输出时 behavior_type 和 severity_level 以字符串形式呈现（非枚举对象）。"
    },
    "PROF-03/EventSetting.json": {
      "module": "PROF-03",
      "type": "string",
      "description": "事件发生时所在环境场景枚举，四值可选字段。用于事件记录的 setting 字段。与个人档案库设计 §2.2 定义一致。"
    },
    "PROF-03/EventUpdate.json": {
      "module": "PROF-03",
      "type": "object",
      "description": "更新事件记录的输入模型（Merge Patch 语义）。所有字段默认为 null（表示不修改此字段）。仅用户显式提供的非 null 字段写入数据库。setting 字段传入显式 null 表示清除已设置的发生场景。更新时 event_time 同样需通过 30 天追溯期校验。"
    },
