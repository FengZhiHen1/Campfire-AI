{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/DEPLOY-04/DATABASE_URL.json",
  "title": "DATABASE_URL",
  "description": "PostgreSQL 数据库连接串，格式为 postgresql+asyncpg://user:pass@host:5432/dbname。由 DEPLOY-05（环境配置）通过环境变量注入，DEPLOY-04（数据库迁移）消费此配置连接目标数据库执行 Alembic 迁移。",
  "type": "string",
  "x-defined-by": "DEPLOY-04",
  "x-consumers": ["DEPLOY-01", "DEPLOY-03", "DEPLOY-05"],
  "x-maturity": "draft",
  "x-contract-type": "configuration",
  "x-version": "1.0.0",
  "pattern": "^postgresql\\+asyncpg://[^:]+:[^@]+@[^:]+:\\d{4,5}/[a-zA-Z0-9_]+$",
  "minLength": 20,
  "maxLength": 512,
  "examples": ["postgresql+asyncpg://campfire:secret123@postgres:5432/campfire"]
}
