{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/PROF-01/ProfileUpdate.json",
  "title": "ProfileUpdate",
  "description": "个人档案更新请求体。家属通过 PUT /api/v1/profiles/{profile_id} 修改已有档案时提交的输入模型。所有字段均为可选——仅提交需要更新的字段，未提交的字段保持原值不变。乐观锁通过比较 updated_at 时间戳实现并发控制。",
  "type": "object",
  "x-defined-by": "PROF-01",
  "x-consumers": ["PROF-07"],
  "x-maturity": "draft",
  "x-contract-type": "input",
  "x-version": "1.0.0",
  "properties": {
    "nickname": {
      "type": ["string", "null"],
      "description": "档案昵称",
      "maxLength": 10
    },
    "birth_date": {
      "type": "string",
      "format": "date",
      "description": "患者的出生日期，不能晚于当前日期"
    },
    "diagnosis_type": {
      "type": "string",
      "enum": ["ASD", "疑似ASD", "其他发育障碍"],
      "description": "诊断类型"
    },
    "primary_behavior": {
      "type": "string",
      "enum": ["刻板行为", "情绪崩溃", "自伤行为", "攻击行为", "社交退缩", "多动"],
      "description": "主要行为类型"
    },
    "language_level": {
      "type": ["string", "null"],
      "enum": ["无语言", "单字词", "短句", "可对话", null],
      "description": "语言水平"
    },
    "sensory_features": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["听觉敏感", "触觉敏感", "味觉敏感", "视觉敏感", "前庭寻求", "本体觉寻求"]
      },
      "maxItems": 6,
      "description": "感官特征（多选）"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["噪音", "环境变化", "陌生人", "任务中断", "社交压力", "感官过载", "身体不适"]
      },
      "maxItems": 7,
      "description": "已知触发因素（多选）"
    },
    "medication_notes": {
      "type": ["string", "null"],
      "description": "用药备注",
      "maxLength": 200
    }
  },
  "additionalProperties": false
}
