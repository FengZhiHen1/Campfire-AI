{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/PROF-01/ProfileCreate.json",
  "title": "ProfileCreate",
  "description": "个人档案创建请求体。家属通过 POST /api/v1/profiles 创建新患者档案时提交的输入模型。必填字段为 birth_date、diagnosis_type、primary_behavior 共 3 项，其余为可选字段（冷启动最低门槛设计）。",
  "type": "object",
  "x-defined-by": "PROF-01",
  "x-consumers": ["PROF-07"],
  "x-maturity": "draft",
  "x-contract-type": "input",
  "x-version": "1.0.0",
  "properties": {
    "nickname": {
      "type": ["string", "null"],
      "description": "档案昵称，家属对患者的日常称呼，仅家庭内部可见。不使用真实姓名",
      "maxLength": 10,
      "examples": ["小明"]
    },
    "birth_date": {
      "type": "string",
      "format": "date",
      "description": "患者的出生日期，格式 YYYY-MM-DD，不能晚于当前日期。系统据此实时计算年龄区间",
      "examples": ["2019-03-15"]
    },
    "diagnosis_type": {
      "type": "string",
      "enum": ["ASD", "疑似ASD", "其他发育障碍"],
      "description": "患者获得的专业诊断结果分类",
      "examples": ["ASD"]
    },
    "primary_behavior": {
      "type": "string",
      "enum": ["刻板行为", "情绪崩溃", "自伤行为", "攻击行为", "社交退缩", "多动"],
      "description": "患者最常出现的行为特征类别",
      "examples": ["刻板行为"]
    },
    "language_level": {
      "type": ["string", "null"],
      "enum": ["无语言", "单字词", "短句", "可对话", null],
      "description": "患者的语言沟通能力评估等级",
      "examples": ["短句"]
    },
    "sensory_features": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["听觉敏感", "触觉敏感", "味觉敏感", "视觉敏感", "前庭寻求", "本体觉寻求"]
      },
      "maxItems": 6,
      "default": [],
      "description": "患者感官反应的特殊性（可多选，至少0项，最多6项）"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["噪音", "环境变化", "陌生人", "任务中断", "社交压力", "感官过载", "身体不适"]
      },
      "maxItems": 7,
      "default": [],
      "description": "已知会引发患者情绪波动或行为问题的环境或情境因素（可多选，至少0项，最多7项）"
    },
    "medication_notes": {
      "type": ["string", "null"],
      "description": "患者当前服用的药物信息，建议注明药名和剂量。仅家属本人和关联老师可见",
      "maxLength": 200,
      "examples": ["利培酮每日 0.5mg，睡前服用"]
    }
  },
  "required": ["birth_date", "diagnosis_type", "primary_behavior"],
  "additionalProperties": false
}
