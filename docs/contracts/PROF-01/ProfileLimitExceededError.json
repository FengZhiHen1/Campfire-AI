{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/PROF-01/ProfileLimitExceededError.json",
  "title": "ProfileLimitExceededError",
  "description": "档案数量超限错误。当家账号下 active 状态的档案数量已达到上限（默认 5 个）时，创建新档案的请求返回此错误。HTTP 409 Conflict。",
  "type": "object",
  "x-defined-by": "PROF-01",
  "x-consumers": ["PROF-07"],
  "x-maturity": "draft",
  "x-contract-type": "error-code",
  "x-version": "1.0.0",
  "properties": {
    "detail": {
      "type": "string",
      "description": "错误提示信息，包含已达上限说明和引导文案",
      "examples": ["您已达到单个账号最多 5 个档案的上限。如需为新的患者建档，可先删除一个不再需要的旧档案（删除操作不可恢复），或使用另一个家属账号创建。"]
    },
    "error_code": {
      "type": "string",
      "const": "PROFILE_LIMIT_EXCEEDED",
      "description": "机器可读的错误码"
    },
    "current_count": {
      "type": "integer",
      "description": "当前账号下的档案数量",
      "minimum": 5,
      "examples": [5]
    },
    "max_allowed": {
      "type": "integer",
      "const": 5,
      "description": "允许的档案数量上限"
    }
  },
  "required": ["detail", "error_code", "current_count", "max_allowed"],
  "additionalProperties": false
}
