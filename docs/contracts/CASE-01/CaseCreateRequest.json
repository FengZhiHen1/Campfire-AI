{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/CASE-01/CaseCreateRequest.json",
  "title": "CaseCreateRequest",
  "description": "案例创建请求体。包含L1原始叙事层4个字段和L2结构化卡片层13个必填字段+2个选填字段。字段通过Pydantic v2进行全量校验。提交前需执行PII检测和EBP一致性检测。",
  "type": "object",
  "x-defined-by": "CASE-01",
  "x-consumers": ["CASE-09"],
  "x-maturity": "draft",
  "x-contract-type": "input",
  "x-version": "1.0.0",
  "required": ["title", "narrative", "source_type", "author_id", "behavior_type", "age_range", "severity", "scene", "ebp_labels", "family_category", "immediate_action", "comforting_phrase", "observation_metrics", "medical_criteria", "evidence_level", "contraindications", "is_template"],
  "properties": {
    "title": { "type": "string", "maxLength": 100, "description": "案例标题（L1），去个性化后的简短名称" },
    "narrative": { "type": "string", "minLength": 100, "description": "原始叙事文本（L1），以自然语言撰写的完整干预故事，必须完成PII脱敏" },
    "source_type": { "type": "string", "enum": ["专家撰写", "机构脱敏", "工单沉淀"], "description": "案例来源类型（L1）" },
    "author_id": { "type": "string", "description": "撰写专家标识（L1），必须为已认证老师或专家账号" },
    "behavior_type": { "type": "string", "enum": ["自伤", "攻击", "刻板", "逃跑", "情绪崩溃", "其他"], "description": "行为类型（L2）" },
    "age_range": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 100 }, "minItems": 2, "maxItems": 2, "description": "适用年龄区间（L2），[起始岁, 结束岁]" },
    "severity": { "type": "string", "enum": ["轻度", "中度", "重度"], "description": "适用严重程度（L2）" },
    "scene": { "type": "string", "enum": ["家庭", "学校", "公共场合", "机构", "不限"], "description": "发生场景（L2）" },
    "ebp_labels": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "循证实践标签（L2），从NCAEP 28种EBP标签中选取至少一项" },
    "family_category": { "type": "string", "enum": ["环境调整", "沟通替代", "行为塑造", "危机安全", "社交引导", "自我管理"], "description": "家属端展示大类（L2）" },
    "immediate_action": { "type": "string", "minLength": 1, "description": "即时安全干预动作（L2），四段式第一段，必须是具体可执行的动作描述" },
    "comforting_phrase": { "type": "string", "minLength": 1, "description": "情绪安抚话术（L2），四段式第二段，使用温和简短确定的语句" },
    "observation_metrics": { "type": "string", "minLength": 1, "description": "后续观察指标（L2），四段式第三段，列出具体可观察的行为或生理指标" },
    "medical_criteria": { "type": "string", "minLength": 1, "description": "就医判断标准（L2），四段式第四段，给出明确的判断条件和建议行动" },
    "evidence_level": { "type": "string", "enum": ["NCAEP循证实践", "机构经验总结", "个案观察记录"], "description": "循证等级（L2）" },
    "contraindications": { "type": "string", "minLength": 1, "description": "禁忌与注意事项（L2），必须具体明确" },
    "is_template": { "type": "boolean", "default": false, "description": "是否模板（L2），普通录入默认为false" },
    "excluded_population": { "type": "string", "description": "不适用人群（L2，选填），明确标注不适宜的患者群体" },
    "attachment_refs": { "type": "array", "items": { "type": "object" }, "default": [], "description": "附件引用列表（L2，选填），仅存储文件名与引用路径" }
  },
  "additionalProperties": false
}
