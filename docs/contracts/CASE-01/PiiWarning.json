{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/CASE-01/PiiWarning.json",
  "title": "PiiWarning",
  "description": "PII检测结果中的单条警告项。提交前对叙事文本执行正则匹配检测，检测到疑似PII时以列表形式在前端提交按钮附近逐条展示，用户确认已脱敏后可继续提交。",
  "type": "object",
  "x-defined-by": "CASE-01",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "output",
  "x-version": "1.0.0",
  "required": ["pii_type", "detected_text", "position_start", "position_end"],
  "properties": {
    "pii_type": { "type": "string", "enum": ["真实姓名", "手机号码", "身份证号", "家庭住址", "学校名称"], "description": "PII类型" },
    "detected_text": { "type": "string", "description": "检测到的疑似PII文本片段" },
    "position_start": { "type": "integer", "minimum": 0, "description": "在叙事文本中的起始字符位置" },
    "position_end": { "type": "integer", "minimum": 0, "description": "在叙事文本中的结束字符位置" }
  }
}
