{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/CASE-01/CaseResponse.json",
  "title": "CaseResponse",
  "description": "案例详情响应体。包含全部L1+L2字段以及系统字段。下游模块通过此接口获取案例全量数据用于审核(CASE-03)、向量化(CASE-04)、模板提炼(CASE-07)等场景。",
  "type": "object",
  "x-defined-by": "CASE-01",
  "x-consumers": ["CASE-03", "CASE-04", "CASE-05", "CASE-07", "KNOW-04"],
  "x-maturity": "draft",
  "x-contract-type": "output",
  "x-version": "1.0.0",
  "required": ["case_id", "status", "title", "narrative", "source_type", "author_id", "behavior_type", "age_range", "severity", "scene", "ebp_labels", "family_category", "immediate_action", "comforting_phrase", "observation_metrics", "medical_criteria", "evidence_level", "contraindications", "is_template", "created_at", "updated_at"],
  "properties": {
    "case_id": { "type": "string", "description": "案例唯一标识，格式CASE-YYYY-NNNN，系统自动生成" },
    "status": { "type": "string", "enum": ["draft", "pending_review", "rejected"], "description": "案例当前状态" },
    "title": { "type": "string", "description": "案例标题" },
    "narrative": { "type": "string", "description": "原始叙事文本" },
    "source_type": { "type": "string", "description": "案例来源类型" },
    "author_id": { "type": "string", "description": "撰写专家标识" },
    "behavior_type": { "type": "string", "description": "行为类型" },
    "age_range": { "type": "array", "items": { "type": "integer" }, "description": "适用年龄区间[起始, 结束]" },
    "severity": { "type": "string", "description": "适用严重程度" },
    "scene": { "type": "string", "description": "发生场景" },
    "ebp_labels": { "type": "array", "items": { "type": "string" }, "description": "循证实践标签列表" },
    "family_category": { "type": "string", "description": "家属端展示大类" },
    "immediate_action": { "type": "string", "description": "即时安全干预动作" },
    "comforting_phrase": { "type": "string", "description": "情绪安抚话术" },
    "observation_metrics": { "type": "string", "description": "后续观察指标" },
    "medical_criteria": { "type": "string", "description": "就医判断标准" },
    "evidence_level": { "type": "string", "description": "循证等级" },
    "contraindications": { "type": "string", "description": "禁忌与注意事项" },
    "is_template": { "type": "boolean", "description": "是否模板" },
    "excluded_population": { "type": "string", "description": "不适用人群" },
    "attachment_refs": { "type": "array", "items": { "type": "object" }, "description": "附件引用列表" },
    "review_comment": { "type": "string", "description": "审核驳回意见，由CASE-03填写" },
    "created_at": { "type": "string", "format": "date-time", "description": "创建时间" },
    "updated_at": { "type": "string", "format": "date-time", "description": "最后编辑时间" }
  }
}
