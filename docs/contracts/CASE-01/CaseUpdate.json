{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/CASE-01/CaseUpdate.json",
  "title": "CaseUpdate",
  "description": "案例更新请求体。所有业务字段均为可选（partial update），通过updated_at实现乐观锁并发控制。编辑pending_review或rejected状态的案例时自动重置状态为draft（编辑即重置约束）。",
  "type": "object",
  "x-defined-by": "CASE-01",
  "x-consumers": ["CASE-09"],
  "x-maturity": "draft",
  "x-contract-type": "input",
  "x-version": "1.0.0",
  "required": ["updated_at"],
  "properties": {
    "title": { "type": "string", "maxLength": 100, "description": "案例标题（L1）" },
    "narrative": { "type": "string", "minLength": 100, "description": "原始叙事文本（L1）" },
    "source_type": { "type": "string", "enum": ["专家撰写", "机构脱敏", "工单沉淀"], "description": "案例来源类型（L1）" },
    "behavior_type": { "type": "string", "enum": ["自伤", "攻击", "刻板", "逃跑", "情绪崩溃", "其他"], "description": "行为类型（L2）" },
    "age_range": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 100 }, "minItems": 2, "maxItems": 2, "description": "适用年龄区间（L2）" },
    "severity": { "type": "string", "enum": ["轻度", "中度", "重度"], "description": "适用严重程度（L2）" },
    "scene": { "type": "string", "enum": ["家庭", "学校", "公共场合", "机构", "不限"], "description": "发生场景（L2）" },
    "ebp_labels": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "循证实践标签（L2）" },
    "family_category": { "type": "string", "enum": ["环境调整", "沟通替代", "行为塑造", "危机安全", "社交引导", "自我管理"], "description": "家属端展示大类（L2）" },
    "immediate_action": { "type": "string", "minLength": 1, "description": "即时安全干预动作（L2）" },
    "comforting_phrase": { "type": "string", "minLength": 1, "description": "情绪安抚话术（L2）" },
    "observation_metrics": { "type": "string", "minLength": 1, "description": "后续观察指标（L2）" },
    "medical_criteria": { "type": "string", "minLength": 1, "description": "就医判断标准（L2）" },
    "evidence_level": { "type": "string", "enum": ["NCAEP循证实践", "机构经验总结", "个案观察记录"], "description": "循证等级（L2）" },
    "contraindications": { "type": "string", "minLength": 1, "description": "禁忌与注意事项（L2）" },
    "is_template": { "type": "boolean", "description": "是否模板（L2）" },
    "excluded_population": { "type": "string", "description": "不适用人群（L2，选填）" },
    "attachment_refs": { "type": "array", "items": { "type": "object" }, "description": "附件引用列表（L2，选填）" },
    "updated_at": { "type": "string", "format": "date-time", "description": "上次读取时的时间戳，用于乐观锁冲突检测。服务端比对后不一致返回409 Conflict" }
  },
  "additionalProperties": false
}
