{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/AUTH-02/LoginRequest.json",
  "title": "LoginRequest",
  "description": "用户登录请求体。接收用户提交的用户名和密码，经 Pydantic 校验后进入登录验证流程。密码不得以明文形式记录在任何存储介质中。",
  "type": "object",
  "x-defined-by": "AUTH-02",
  "x-consumers": [
    "AUTH-05"
  ],
  "x-maturity": "draft",
  "x-contract-type": "input",
  "x-version": "1.0.0",
  "properties": {
    "username": {
      "type": "string",
      "description": "登录名称。必须为已注册且处于正常状态的用户名。长度 4-32 字符，仅允许字母、数字、下划线和连字符。系统使用 LOWER() 函数进行大小写不敏感查询。",
      "minLength": 4,
      "maxLength": 32,
      "pattern": "^[a-zA-Z0-9_-]+$",
      "examples": ["zhang_san", "teacher_li", "expert_wang"]
    },
    "password": {
      "type": "string",
      "description": "登录凭证。系统不传输或比对密码明文，仅通过 bcrypt 哈希比对验证。至少 8 位。",
      "minLength": 8,
      "examples": ["Abc12345", "MyP@ssw0rd"]
    }
  },
  "required": ["username", "password"],
  "additionalProperties": false
}
