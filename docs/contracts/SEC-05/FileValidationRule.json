{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-05/FileValidationRule.json",
  "title": "FileValidationRule",
  "description": "文件校验规则配置，定义允许的文件类型白名单和大小上限。由意图文档 1.12 决策 4、5 确定。",
  "type": "object",
  "x-defined-by": "SEC-05",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "shared-model",
  "x-version": "1.0.0",
  "properties": {
    "allowed_mime_types": {
      "type": "array",
      "items": { "type": "string" },
      "description": "允许的 MIME 类型白名单",
      "minItems": 1,
      "examples": [["application/pdf", "image/jpeg", "image/png", "image/webp", "video/mp4", "application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"]]
    },
    "allowed_extensions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "允许的文件扩展名白名单，与 MIME 类型双重验证",
      "minItems": 1,
      "examples": [[".pdf", ".jpg", ".jpeg", ".png", ".webp", ".mp4", ".doc", ".docx"]]
    },
    "max_size_bytes": {
      "type": "integer",
      "description": "文件大小上限（字节）。通用默认值 10 * 1024 * 1024 = 10485760 (10MB)",
      "minimum": 1,
      "examples": [10485760, 2097152]
    }
  },
  "required": ["allowed_mime_types", "allowed_extensions", "max_size_bytes"],
  "additionalProperties": false
}
