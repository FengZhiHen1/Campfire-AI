{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-05/ValidationErrorResponse.json",
  "title": "ValidationErrorResponse",
  "description": "校验失败时的 HTTP 响应体，覆盖 FastAPI 默认 422 格式。包含字段级错误明细列表。由意图文档 1.6.2 错误明细结构定义，设计文档 1.1 决策 7 确定格式。",
  "type": "object",
  "x-defined-by": "SEC-05",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "output",
  "x-version": "1.0.0",
  "properties": {
    "errors": {
      "type": "array",
      "items": {
        "$ref": "./ValidationErrorItem.json"
      },
      "description": "校验失败的错误明细列表，至少包含 1 项",
      "minItems": 1
    }
  },
  "required": ["errors"],
  "additionalProperties": false
