{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-05/FileValidationResult.json",
  "title": "FileValidationResult",
  "description": "文件校验结果，包含通过/拒绝状态、检测到的 MIME 类型、文件大小。由意图文档 1.6.2 输出定义派生。",
  "type": "object",
  "x-defined-by": "SEC-05",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "shared-model",
  "x-version": "1.0.0",
  "properties": {
    "is_valid": {
      "type": "boolean",
      "description": "文件是否通过校验。true=允许上传，false=拒绝",
      "examples": [true, false]
    },
    "error_message": {
      "type": "string",
      "description": "校验失败时的错误说明。仅 is_valid=false 时有值",
      "examples": ["文件类型不允许，仅支持：pdf, jpg, png, webp, mp4, doc, docx"]
    },
    "detected_mime_type": {
      "type": "string",
      "description": "通过文件头魔数检测到的真实 MIME 类型",
      "minLength": 1,
      "examples": ["application/pdf", "image/png"]
    },
    "file_size_bytes": {
      "type": "integer",
      "description": "文件大小（字节）",
      "minimum": 1,
      "examples": [2097152, 10485760]
    }
  },
  "required": ["is_valid", "detected_mime_type", "file_size_bytes"],
  "additionalProperties": false
}
