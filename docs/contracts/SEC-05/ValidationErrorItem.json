{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-05/ValidationErrorItem.json",
  "title": "ValidationErrorItem",
  "description": "字段级校验错误明细，包含字段名、不通过原因、期望约束条件。由意图文档 1.6.2 错误明细结构定义。",
  "type": "object",
  "x-defined-by": "SEC-05",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "shared-model",
  "x-version": "1.0.0",
  "properties": {
    "field": {
      "type": "string",
      "description": "校验失败的字段名",
      "minLength": 1,
      "examples": ["age", "email", "behavior_description"]
    },
    "reason": {
      "type": "string",
      "description": "不通过原因的机器可读标识",
      "minLength": 1,
      "examples": ["must_be_positive_integer", "value_not_in_enum", "field_required"]
    },
    "constraint": {
      "type": "string",
      "description": "期望的约束条件，面向调用方的可读说明",
      "minLength": 1,
      "examples": ["value >= 0", "must be one of: ['open', 'closed']", "field is required"]
    }
  },
  "required": ["field", "reason", "constraint"],
  "additionalProperties": false
}
