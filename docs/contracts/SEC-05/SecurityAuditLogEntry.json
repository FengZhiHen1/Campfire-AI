{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-05/SecurityAuditLogEntry.json",
  "title": "SecurityAuditLogEntry",
  "description": "安全审计日志条目，记录校验异常和安全检测事件。由意图文档业务约束 6（保留 180 天）和设计文档 1.1 决策 6 确定。",
  "type": "object",
  "x-defined-by": "SEC-05",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "shared-model",
  "x-version": "1.0.0",
  "properties": {
    "trace_id": {
      "type": "string",
      "description": "请求链路追踪 ID，关联 request_id",
      "minLength": 1,
      "examples": ["a1b2c3d4-e5f6-7890-abcd-ef1234567890"]
    },
    "event_type": {
      "type": "string",
      "description": "安全事件类型标识",
      "enum": ["sql_injection", "xss_payload", "malformed_request"],
      "examples": ["sql_injection"]
    },
    "detection_detail": {
      "type": "string",
      "description": "检测详情，包含检测到的异常特征摘要。不得包含用户原始输入全文",
      "minLength": 1,
      "examples": ["SQL injection pattern detected: 'UNION SELECT' keyword in query_param 'sort_by'"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "事件发生时间（ISO 8601 格式）",
      "examples": ["2026-05-26T17:00:00+08:00"]
    }
  },
  "required": ["trace_id", "event_type", "detection_detail", "timestamp"],
  "additionalProperties": false
}
