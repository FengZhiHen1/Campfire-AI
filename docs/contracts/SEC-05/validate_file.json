{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "docs/contracts/SEC-05/validate_file.json",
  "title": "validate_file",
  "description": "文件校验函数合约，对上传文件执行 MIME 类型白名单和大小上限双重校验。由意图文档 1.12 决策 4、5 和设计文档 1.7 禁止行为 7 确定。",
  "type": "object",
  "x-defined-by": "SEC-05",
  "x-consumers": [],
  "x-maturity": "draft",
  "x-contract-type": "shared-model",
  "x-version": "1.0.0",
  "properties": {
    "file": {
      "type": "object",
      "description": "用户上传的文件对象（FastAPI UploadFile），包含文件名、MIME 头、文件内容"
    },
    "rules": {
      "$ref": "./FileValidationRule.json",
      "description": "文件校验规则配置，包含允许的 MIME 类型白名单、扩展名白名单和大小上限"
    }
  },
  "required": ["file", "rules"],
  "additionalProperties": false,
  "x-return-type": "FileValidationResult",
  "x-return-description": "文件校验结果，包含 is_valid、error_message、detected_mime_type、file_size_bytes"
}
